ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Optional: only required if you use OpenAI models (gpt-* / chatgpt-*)
OPENAI_API_KEY=your-openai-api-key-here
# Optional: only required if you use Google Gemini models (gemini-*)
GOOGLE_API_KEY=your-google-api-key-here
# Optional: only required if you use Moonshot Kimi models (kimi-*)
MOONSHOT_API_KEY=your-moonshot-api-key-here
# Optional: only required if you use OpenRouter models (openrouter/*)
OPEN_ROUTER_API_KEY=your-openrouter-api-key-here
# OPENROUTER_API_KEY=your-openrouter-api-key-here
# Optional: override the default OpenRouter endpoint
# OPEN_ROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional: only required if you use direct Z.AI models (zai/*)
ZAI_API_KEY=your-z-ai-api-key-here
# Optional: override the default Z.AI endpoint
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
# Optional: only required if you use DashScope Qwen or GLM models
# Any of these variable names work.
DASHSCOPE_API_KEY=your-dashscope-api-key-here
# ALI_BABA_API_KEY=your-dashscope-api-key-here
# BAILIAN_API_KEY=your-dashscope-api-key-here
# Optional: override the default DashScope OpenAI-compatible endpoint for Qwen
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Optional: override the default DashScope OpenAI-compatible endpoint for GLM
# GLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Optional: only required if you use xAI Grok models (grok-*)
XAI_API_KEY=your-xai-api-key-here

# Optional: pricing file path for cost estimation
# PRICING_FILE=pricing.json
